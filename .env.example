# =============================================================================
# ZOOM Government Services — Environment variable template
# -----------------------------------------------------------------------------
# Copy to ".env" for local notes, OR set these on the server.
# These are read by public/contact.php via getenv().
#
# IMPORTANT:
#   * Do NOT commit a real .env file (it is git-ignored).
#   * Deployment/FTP credentials are NOT stored here — they live only in
#     GitHub > Settings > Secrets and variables > Actions (see SETUP.md).
#
# On GoDaddy/cPanel, set these via either:
#   a) cPanel > "MultiPHP INI Editor" / a .user.ini file, or
#   b) an .htaccess line:  SetEnv CONTACT_TO "you@zoomgovermentservices.com"
# =============================================================================

# Inbox that contact-form submissions are delivered to.
CONTACT_TO="hello@zoomgovermentservices.com"

# From address for outgoing notification mail.
# Use an address ON your own domain for best deliverability (SPF/DKIM).
CONTACT_FROM="website@zoomgovermentservices.com"
